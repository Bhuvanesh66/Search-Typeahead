{
  "name": "search-typeahead-backend",
  "version": "1.0.0",
  "description": "Search typeahead system backend: Trie suggestions, distributed Redis cache with consistent hashing, batched writes, trending.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node --env-file=.env dist/server.js",
    "worker": "tsx watch --env-file=.env src/workers/worker.ts",
    "worker:start": "node --env-file=.env dist/workers/worker.js",
    "build": "tsc -p tsconfig.json",
    "dataset:generate": "tsx scripts/generate-dataset.ts",
    "dataset:load": "tsx scripts/load-dataset.ts",
    "warm": "tsx scripts/warm-cache.ts",
    "perf": "tsx scripts/perf.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "pino": "^9.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
