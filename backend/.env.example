# ─────────────────────────────────────────────────────────────────────────────
# Search Typeahead System — backend configuration
# Copy to `.env` and adjust as needed. All values have safe defaults in config.
# ─────────────────────────────────────────────────────────────────────────────

# HTTP
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Distributed cache — comma-separated host:port list (one per Redis node)
REDIS_NODES=localhost:6380,localhost:6381,localhost:6382

# Queue lives on the first cache node by default; override to dedicate a node
QUEUE_REDIS=localhost:6380

# Consistent hashing
VIRTUAL_NODES=150

# Cache TTLs (milliseconds)
CACHE_TTL_SUGGEST_MS=60000
CACHE_TTL_TRENDING_MS=30000
CACHE_TTL_QUERY_MS=300000

# Suggestions
TOP_K=10
# Precompute top-K only up to this prefix depth (caps Trie memory). 0 = unlimited.
MAX_PREFIX_DEPTH=0

# Batch writes
BATCH_SIZE=1000
FLUSH_INTERVAL_MS=2000
STREAM_KEY=search_events
CONSUMER_GROUP=batch_workers
CONSUMER_NAME=worker-1

# Sampling lever (optional). 1.0 = process every search; 0.001 = process ~0.1%.
SAMPLE_RATE=1.0

# Trending / ranking
# blendedScore = ALPHA * norm(totalCount) + (1 - ALPHA) * norm(recentScore)
TRENDING_ALPHA=0.7
TRENDING_DECAY=0.9
TRENDING_DECAY_INTERVAL_MS=60000
TRENDING_TOP_N=20

# Dataset
DATASET_PATH=../datasets/queries.csv
